@model StudentManagementSystem.Models.Student

@{
    ViewData["Title"] = "Add Student";
}

<div class="container mt-4">
    <h2>Add New Student</h2>
    <hr />

    @if (ViewBag.ErrorMessage != null)
    {
        <div class="alert alert-danger">
            @ViewBag.ErrorMessage
        </div>
    }

    <div class="row">
        <div class="col-md-6">
            <form asp-action="AddStudent" method="post">
                <div class="mb-3">
                    <label asp-for="StudentId" class="form-label">Student ID</label>
                    <input asp-for="StudentId" class="form-control" required placeholder="e.g., S101" />
                </div>
                <div class="mb-3">
                    <label asp-for="FullName" class="form-label">Full Name</label>
                    <input asp-for="FullName" class="form-control" required placeholder="e.g., John Doe" />
                </div>
                <div class="mb-3">
                    <label asp-for="Email" class="form-label">Email Address</label>
                    <input asp-for="Email" type="email" class="form-control" placeholder="e.g., john@example.com" />
                </div>
                <div class="mb-3">
                    <label asp-for="Phone" class="form-label">Phone Number</label>
                    <input asp-for="Phone" type="text" class="form-control" placeholder="e.g., 555-1234" />
                </div>
                <div class="mb-3">
                    <label asp-for="Department" class="form-label">Department</label>
                    <input asp-for="Department" type="text" class="form-control" placeholder="e.g., Computer Science" />
                </div>
                <div class="mb-3">
                    <label asp-for="Address" class="form-label">Address</label>
                    <textarea asp-for="Address" class="form-control" rows="2" placeholder="e.g., 123 Main St."></textarea>
                </div>
                <div class="mb-3">
                    <label asp-for="AdvisorId" class="form-label">Advisor (Teacher ID)</label>
                    <input asp-for="AdvisorId" class="form-control" placeholder="e.g., T201" />
                    <div class="form-text">Enter the Teacher ID who is advising this student.</div>
                </div>

                <button type="submit" class="btn btn-primary">Save Student via PL/SQL</button>
                <a href="/Admin/AllStudents" class="btn btn-secondary ms-2">Cancel</a>
            </form>
        </div>
    </div>
</div>
