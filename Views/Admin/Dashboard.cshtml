@{
    ViewData["Title"] = "Admin Dashboard";
}

<style>
    /* Conventional Admin Dashboard Layout */
    .admin-layout {
        display: flex;
        min-height: calc(100vh - 76px); /* Adjust based on navbar height */
        margin-top: -1rem; /* Offset any default container margins */
        margin-left: calc(-50vw + 50%); /* Break out of default .container if present */
        margin-right: calc(-50vw + 50%);
        width: 100vw;
    }
    .admin-sidebar {
        width: 280px;
        background-color: #1e293b; /* Dark Slate */
        color: #f8fafc;
        display: flex;
        flex-direction: column;
        flex-shrink: 0;
        box-shadow: 2px 0 5px rgba(0,0,0,0.1);
    }
    .admin-sidebar .nav-link {
        color: #cbd5e1;
        padding: 0.75rem 1.25rem;
        border-radius: 0;
        border-left: 3px solid transparent;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .admin-sidebar .nav-link:hover, .admin-sidebar .nav-link.active {
        background-color: #334155;
        color: #fff;
        border-left-color: #38bdf8;
    }
    .admin-main {
        flex-grow: 1;
        padding: 2rem;
        background-color: transparent;
        overflow-y: auto;
    }
    .stat-card {
        border: none;
        border-radius: 0.5rem;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        transition: transform 0.2s;
    }
    .stat-card:hover {
        transform: translateY(-3px);
    }
    /* Hide the default layout container padding/margins just for this page if possible */
    .pb-3 { padding-bottom: 0 !important; }
</style>

<div class="admin-layout">
    <!-- Sidebar -->
    <div class="admin-sidebar pt-3">
        <div class="px-3 mb-4">
            <h5 class="text-white mb-0"><i class="bi bi-shield-lock-fill me-2"></i>Admin Panel</h5>
            <small class="text-muted">Management System</small>
        </div>
        <ul class="nav flex-column mb-auto">
            <li class="nav-item">
                <a href="/Admin/Dashboard" class="nav-link active">
                    <i class="bi bi-speedometer2"></i> Dashboard
                </a>
            </li>
            <li class="nav-item">
                <a href="/Admin/AllStudents" class="nav-link">
                    <i class="bi bi-people"></i> Manage Students
                </a>
            </li>
            <li class="nav-item">
                <a href="/Admin/AllTeachers" class="nav-link">
                    <i class="bi bi-person-workspace"></i> Manage Teachers
                </a>
            </li>
            <li class="nav-item">
                <a href="/Admin/AllCourses" class="nav-link">
                    <i class="bi bi-journal-text"></i> Courses
                </a>
            </li>
            <li class="nav-item">
                <a href="/Admin/AllDepartments" class="nav-link">
                    <i class="bi bi-building"></i> Departments
                </a>
            </li>
            <li class="nav-item">
                <a href="/Admin/Library" class="nav-link">
                    <i class="bi bi-book"></i> Library
                </a>
            </li>
        </ul>
        <div class="mt-auto p-3">
            <a href="/" class="btn btn-danger w-100"><i class="bi bi-box-arrow-right me-2"></i> Logout</a>
        </div>
    </div>

    <!-- Main Content -->
    <div class="admin-main">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h3 class="mb-1">Dashboard Overview</h3>
                <p class="text-muted mb-0">Welcome back, Administrator!</p>
            </div>
            <div>
                <span class="badge bg-primary fs-6 py-2 px-3"><i class="bi bi-calendar3 me-2"></i>@DateTime.Now.ToString("dd MMM yyyy")</span>
            </div>
        </div>

        <!-- Stats Row -->
        <div class="row mb-4">
            <div class="col-md-4 mb-3">
                <div class="card stat-card h-100">
                    <div class="card-body d-flex align-items-center">
                        <div class="bg-primary bg-opacity-10 text-primary p-3 rounded-3 me-3">
                            <i class="bi bi-people-fill fs-2"></i>
                        </div>
                        <div>
                            <h6 class="text-muted mb-1 text-uppercase fw-bold" style="font-size: 0.8rem;">Total Students</h6>
                            <h3 class="mb-0 fw-bold">@ViewBag.TotalStudents</h3>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-3">
                <div class="card stat-card h-100">
                    <div class="card-body d-flex align-items-center">
                        <div class="bg-success bg-opacity-10 text-success p-3 rounded-3 me-3">
                            <i class="bi bi-person-workspace fs-2"></i>
                        </div>
                        <div>
                            <h6 class="text-muted mb-1 text-uppercase fw-bold" style="font-size: 0.8rem;">Total Teachers</h6>
                            <h3 class="mb-0 fw-bold">@ViewBag.TotalTeachers</h3>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-3">
                <div class="card stat-card h-100">
                    <div class="card-body d-flex align-items-center">
                        <div class="bg-warning bg-opacity-10 text-warning p-3 rounded-3 me-3">
                            <i class="bi bi-book-half fs-2"></i>
                        </div>
                        <div>
                            <h6 class="text-muted mb-1 text-uppercase fw-bold" style="font-size: 0.8rem;">Pending Books</h6>
                            <h3 class="mb-0 fw-bold">0</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="card stat-card mb-4">
            <div class="card-header border-bottom py-3">
                <h5 class="mb-0 fw-bold"><i class="bi bi-lightning-charge-fill text-warning me-2"></i>Quick Actions</h5>
            </div>
            <div class="card-body">
                <div class="row g-3 mb-3">
                    <div class="col-md-3 col-sm-6">
                        <a href="/Admin/AddStudent" class="btn btn-outline-primary w-100 py-3 d-flex flex-column align-items-center gap-2">
                            <i class="bi bi-person-plus fs-3"></i>
                            <span>Add Student</span>
                        </a>
                    </div>
                    <div class="col-md-3 col-sm-6">
                        <a href="/Admin/AddTeacher" class="btn btn-outline-success w-100 py-3 d-flex flex-column align-items-center gap-2">
                            <i class="bi bi-person-plus-fill fs-3"></i>
                            <span>Add Teacher</span>
                        </a>
                    </div>
                    <div class="col-md-3 col-sm-6">
                        <a href="/Admin/AddCourse" class="btn btn-outline-warning w-100 py-3 d-flex flex-column align-items-center gap-2">
                            <i class="bi bi-journal-plus fs-3"></i>
                            <span>Add Course</span>
                        </a>
                    </div>
                    <div class="col-md-3 col-sm-6">
                        <a href="/Admin/AddDepartment" class="btn btn-outline-info w-100 py-3 d-flex flex-column align-items-center gap-2">
                            <i class="bi bi-building-add fs-3"></i>
                            <span>Add Department</span>
                        </a>
                    </div>
                </div>

                <!-- Manage Actions -->
                <div class="row g-3">
                    <div class="col-md-2 col-sm-4">
                        <a href="/Admin/AllStudents" class="btn btn-outline-primary w-100 py-3 d-flex flex-column align-items-center gap-2">
                            <i class="bi bi-people fs-3"></i>
                            <span>Manage Students</span>
                        </a>
                    </div>
                    <div class="col-md-2 col-sm-4">
                        <a href="/Admin/AllTeachers" class="btn btn-outline-success w-100 py-3 d-flex flex-column align-items-center gap-2">
                            <i class="bi bi-person-workspace fs-3"></i>
                            <span>Manage Teachers</span>
                        </a>
                    </div>
                    <div class="col-md-3 col-sm-4">
                        <a href="/Admin/AllCourses" class="btn btn-outline-warning w-100 py-3 d-flex flex-column align-items-center gap-2">
                            <i class="bi bi-journal-text fs-3"></i>
                            <span>Manage Courses</span>
                        </a>
                    </div>
                    <div class="col-md-3 col-sm-6">
                        <a href="/Admin/AllDepartments" class="btn btn-outline-info w-100 py-3 d-flex flex-column align-items-center gap-2">
                            <i class="bi bi-building fs-3"></i>
                            <span>Manage Departments</span>
                        </a>
                    </div>
                    <div class="col-md-2 col-sm-6">
                        <a href="/Admin/Library" class="btn btn-outline-secondary w-100 py-3 d-flex flex-column align-items-center gap-2">
                            <i class="bi bi-book fs-3"></i>
                            <span>Library</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>
