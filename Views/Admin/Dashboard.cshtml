@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container mt-4">
    <div class="row">
        <!-- Sidebar Navigation -->
        <div class="col-md-3">
            <div class="list-group">
                <a href="#" class="list-group-item list-group-item-action active" aria-current="true">
                    Admin Menu
                </a>
                <a href="/Admin/AddStudent" class="list-group-item list-group-item-action">Add Student</a>
                <a href="/Admin/UpdateStudent" class="list-group-item list-group-item-action">Update Student</a>
                <a href="/Admin/DeleteStudent" class="list-group-item list-group-item-action">Delete Student</a>
                <a href="/Admin/AllStudents" class="list-group-item list-group-item-action">See All Students</a>
                <a href="/Admin/Library" class="list-group-item list-group-item-action">Library Management</a>
            </div>
            <div class="mt-3">
                <a href="/" class="btn btn-danger w-100">Logout</a>
            </div>
        </div>

        <!-- Main Content Area -->
        <div class="col-md-9">
            <div class="card shadow-sm">
                <div class="card-header bg-dark text-white">
                    <h5>Welcome, Administrator</h5>
                </div>
                <div class="card-body">
                    <h5 class="card-title">Dashboard Overview</h5>
                    <p class="card-text">Welcome to the Student Management System. From the menu on the left, you can manage students, assign courses, and approve library book requests.</p>
                    
                    <div class="row mt-4">
                        <div class="col-sm-4">
                            <div class="card bg-light">
                                <div class="card-body text-center">
                                    <h6 class="card-title">Total Students</h6>
                                    <h3>0</h3>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="card bg-light">
                                <div class="card-body text-center">
                                    <h6 class="card-title">Pending Book Requests</h6>
                                    <h3>0</h3>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="card bg-light">
                                <div class="card-body text-center">
                                    <h6 class="card-title">Total Teachers</h6>
                                    <h3>0</h3>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-5 alert alert-info">
                        <strong>Developer Note:</strong> Database connections using Oracle PL/SQL (ADO.NET) will populate these numbers and handle the actions in the coming weeks.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
