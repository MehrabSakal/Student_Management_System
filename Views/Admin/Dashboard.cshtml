@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-3">
            <div class="list-group">
                <a href="#" class="list-group-item list-group-item-action active" aria-current="true">
                    Admin Menu
                </a>
                <a href="/Admin/AddDepartment" class="list-group-item list-group-item-action">Add Department</a>
                <a href="/Admin/AddCourse" class="list-group-item list-group-item-action">Add Course</a>
                <a href="/Admin/AddStudent" class="list-group-item list-group-item-action">Add Student</a>
                <a href="/Admin/AddTeacher" class="list-group-item list-group-item-action">Add Teacher</a>
                <a href="/Admin/AllDepartments" class="list-group-item list-group-item-action">See All Departments</a>
                <a href="/Admin/AllCourses" class="list-group-item list-group-item-action">See All Courses</a>
                <a href="/Admin/AllStudents" class="list-group-item list-group-item-action">See All Students</a>
                <a href="/Admin/AllTeachers" class="list-group-item list-group-item-action">See All Teachers</a>
                <a href="/Admin/Library" class="list-group-item list-group-item-action">Library Management</a>
            </div>
            <div class="mt-3">
                <a href="/" class="btn btn-danger w-100">Logout</a>
            </div>
        </div>

        <div class="col-md-9">
            <div class="card shadow-sm">
                <div class="card-header bg-dark text-white">
                    <h5>Welcome, Administrator</h5>
                </div>
                <div class="card-body">
                    <h5 class="card-title">Dashboard Overview</h5>
                    <p class="card-text">Welcome to the Student Management System. From the menu on the left, you can manage students, assign courses, and approve library book requests.</p>
                    
                    <div class="row mt-4">
                        <div class="col-sm-4">
                            <div class="card bg-light">
                                <div class="card-body text-center">
                                    <h6 class="card-title">Total Students</h6>
                                    <h3>@ViewBag.TotalStudents</h3>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="card bg-light">
                                <div class="card-body text-center">
                                    <h6 class="card-title">Pending Book Requests</h6>
                                    <h3>0</h3>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="card bg-light">
                                <div class="card-body text-center">
                                    <h6 class="card-title">Total Teachers</h6>
                                    <h3>@ViewBag.TotalTeachers</h3>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
