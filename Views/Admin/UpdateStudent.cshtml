@model StudentManagementSystem.Models.Student

@{
    ViewData["Title"] = "Update Student";
}

<div class="container mt-4">
    <h2>Update Student Details</h2>
    <hr />

    @if (ViewBag.ErrorMessage != null)
    {
        <div class="alert alert-danger">
            @ViewBag.ErrorMessage
        </div>
    }

    <div class="row">
        <div class="col-md-6">
            <form asp-action="UpdateStudent" method="post">
                <!-- Keep StudentId readonly because it's the Primary Key -->
                <div class="mb-3">
                    <label asp-for="StudentId" class="form-label">Student ID</label>
                    <input asp-for="StudentId" class="form-control" disabled />
                    <input type="hidden" asp-for="StudentId" />
                    <div class="form-text">Student ID cannot be changed.</div>
                </div>
                <div class="mb-3">
                    <label asp-for="FullName" class="form-label">Full Name</label>
                    <input asp-for="FullName" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label asp-for="Email" class="form-label">Email Address</label>
                    <input asp-for="Email" type="email" class="form-control" />
                </div>
                <div class="mb-3">
                    <label asp-for="Phone" class="form-label">Phone Number</label>
                    <input asp-for="Phone" type="text" class="form-control" />
                </div>
                <div class="mb-3">
                    <label asp-for="Department" class="form-label">Department</label>
                    <input asp-for="Department" type="text" class="form-control" />
                </div>
                <div class="mb-3">
                    <label asp-for="Address" class="form-label">Address</label>
                    <textarea asp-for="Address" class="form-control" rows="2"></textarea>
                </div>
                <div class="mb-3">
                    <label asp-for="AdvisorId" class="form-label">Advisor (Teacher ID)</label>
                    <input asp-for="AdvisorId" class="form-control" />
                </div>

                <button type="submit" class="btn btn-warning">Update Student via PL/SQL</button>
                <a href="/Admin/AllStudents" class="btn btn-secondary ms-2">Cancel</a>
            </form>
        </div>
    </div>
</div>
