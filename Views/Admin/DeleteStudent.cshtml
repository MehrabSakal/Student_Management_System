@{
    ViewData["Title"] = "Delete Student";
}

<div class="container mt-4">
    <h2>Delete Student</h2>
    <hr />

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">
            @TempData["ErrorMessage"]
        </div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["SuccessMessage"]
        </div>
    }

    <div class="row">
        <div class="col-md-6">
            <div class="card shadow-sm border-danger">
                <div class="card-header bg-danger text-white">
                    <strong>Warning: This action cannot be undone</strong>
                </div>
                <div class="card-body">
                    <form action="/Admin/DeleteStudent" method="post" onsubmit="return confirm('Are you sure you want to permanently delete this student?');">
                        <div class="mb-3">
                            <label for="id" class="form-label">Enter Student ID to Delete</label>
                            <input type="text" class="form-control" id="id" name="id" required placeholder="e.g., S101" />
                            <div class="form-text text-danger">The PL/SQL procedure will permanently remove this record.</div>
                        </div>
                        <button type="submit" class="btn btn-danger">Delete Student via PL/SQL</button>
                        <a href="/Admin/Dashboard" class="btn btn-secondary ms-2">Cancel</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
