@model List<StudentManagementSystem.Models.Teacher>

@{
    ViewData["Title"] = "All Teachers";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>All Teachers Directory</h2>
        <a href="/Admin/AddTeacher" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add New Teacher
        </a>
    </div>
    
    <hr />

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (ViewBag.ErrorMessage != null)
    {
        <div class="alert alert-warning">
            @ViewBag.ErrorMessage
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-hover table-striped mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Teacher ID</th>
                        <th>First Name</th>
                        <th>Last Name</th>
                        <th>Email</th>
                        <th>Designation</th>
                        <th>Department ID</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Count > 0)
                    {
                        foreach (var teacher in Model)
                        {
                            <tr>
                                <td><strong>@teacher.TeacherId</strong></td>
                                <td>@teacher.FirstName</td>
                                <td>@teacher.LastName</td>
                                <td>@teacher.Email</td>
                                <td>@teacher.Designation</td>
                                <td>@teacher.DeptId</td>
                                <td class="text-center">
                                    <div class="btn-group" role="group">
                                        <a href="/Admin/UpdateTeacher?id=@teacher.TeacherId" class="btn btn-sm btn-outline-primary" title="Edit Teacher">
                                            <i class="bi bi-pencil"></i> Edit
                                        </a>
                                        <form method="post" action="/Admin/DeleteTeacher" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this teacher? This may also affect students advised by them.');">
                                            <input type="hidden" name="id" value="@teacher.TeacherId" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete Teacher">
                                                <i class="bi bi-trash"></i> Delete
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">
                                No teachers found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    
    <div class="mt-4">
        <a href="/Admin/Dashboard" class="btn btn-secondary">Back to Dashboard</a>
    </div>
</div>
