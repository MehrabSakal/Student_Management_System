@model IEnumerable<StudentManagementSystem.Models.BookRequest>
@{
    ViewData["Title"] = "Pending Borrow Requests";
}

<div class="container page-container">
    <div class="row">
        <div class="wide-wrapper">
            <div class="header-actions">
                <h3>Pending Borrow Requests</h3>
                <a asp-action="Library" class="btn btn-outline-secondary">Back to Library</a>
            </div>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success">@TempData["SuccessMessage"]</div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
            }

            <div class="panel">
                <div class="panel-body">
                    @if (Model == null || !Model.Any())
                    {
                        <div class="alert alert-info mb-0">No pending requests at this time.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead>
                                    <tr>
                                        <th>Date</th>
                                        <th>Student</th>
                                        <th>Book Title</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var request in Model)
                                    {
                                        <tr>
                                            <td>@request.RequestDate.ToString("MMM dd, yyyy")</td>
                                            <td>@request.StudentName (@request.StudentId)</td>
                                            <td>@request.BookTitle</td>
                                            <td>
                                                <form method="post" class="d-inline">
                                                    <input type="hidden" name="requestId" value="@request.RequestId" />
                                                    <button type="submit" asp-action="ApproveRequest" class="btn btn-sm btn-success">Approve</button>
                                                    <button type="submit" asp-action="RejectRequest" class="btn btn-sm btn-danger">Reject</button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
