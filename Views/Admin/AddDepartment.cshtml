@model StudentManagementSystem.Models.Department

@{
    ViewData["Title"] = "Add Department";
}

<div class="container mt-4">
    <h2>Add New Department</h2>
    <hr />

    @if (ViewBag.ErrorMessage != null)
    {
        <div class="alert alert-danger">
            @ViewBag.ErrorMessage
        </div>
    }

    <div class="row">
        <div class="col-md-6">
            <form asp-action="AddDepartment" method="post">
                <div class="mb-3">
                    <label asp-for="DeptId" class="form-label">Department ID</label>
                    <input asp-for="DeptId" class="form-control" required  />
                </div>
                <div class="mb-3">
                    <label asp-for="DeptName" class="form-label">Department Name</label>
                    <input asp-for="DeptName" class="form-control" required  />
                </div>
                <div class="mb-3">
                    <label asp-for="Faculty" class="form-label">Faculty</label>
                    <input asp-for="Faculty" type="text" class="form-control"  />
                </div>
                <div class="mb-3">
                    <label asp-for="NoOfStudents" class="form-label">Number of Students</label>
                    <input asp-for="NoOfStudents" type="number" class="form-control"  />
                </div>
                <button type="submit" class="btn btn-primary">Save Department</button>
                <a href="/Admin/Dashboard" class="btn btn-secondary ms-2">Cancel</a>
            </form>
        </div>
    </div>
</div>
