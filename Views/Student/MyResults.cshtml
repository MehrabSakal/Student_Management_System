@model IEnumerable<StudentManagementSystem.Models.StudentResult>
@{
    ViewData["Title"] = "My Results";
    
    double totalGpa = 0;
    int gradedCourses = 0;
    
    foreach (var result in Model)
    {
        if (result.GPA.HasValue)
        {
            totalGpa += result.GPA.Value;
            gradedCourses++;
        }
    }
    
    double cgpa = gradedCourses > 0 ? totalGpa / gradedCourses : 0;
}

<div class="container page-container mt-4">
    <div class="panel">
        <div class="panel-header-info d-flex justify-content-between align-items-center">
            <h3 class="mb-0"><i class="bi bi-graph-up me-2"></i>Academic Results</h3>
        </div>
        <div class="panel-body">
            
            <div class="card bg-dark border-secondary mb-4 p-4 text-center">
                <h4 class="text-muted mb-2">Overall CGPA</h4>
                @if (gradedCourses > 0)
                {
                    <h1 class="display-3 fw-bold @(cgpa >= 3.0 ? "text-success" : (cgpa >= 2.0 ? "text-warning" : "text-danger"))">
                        @cgpa.ToString("0.00")
                    </h1>
                    <p class="text-muted">Based on @gradedCourses graded course(s)</p>
                }
                else
                {
                    <h2 class="text-muted fw-bold">N/A</h2>
                    <p class="text-muted">No graded courses yet.</p>
                }
            </div>

            <h4 class="mb-3 text-light">Course Breakdown</h4>
            
            @if (!Model.Any())
            {
                <p class="text-muted">You are not enrolled in any courses.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr>
                                <th>Course No</th>
                                <th>Course Name</th>
                                <th class="text-center">Marks</th>
                                <th class="text-center">Grade</th>
                                <th class="text-center">GPA</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var result in Model)
                            {
                                <tr>
                                    <td class="fw-bold text-primary">@result.CourseNo</td>
                                    <td>@result.CourseName</td>
                                    <td class="text-center">
                                        @(result.Marks.HasValue ? result.Marks.Value.ToString("0.00") : "-")
                                    </td>
                                    <td class="text-center">
                                        @if (result.Marks.HasValue)
                                        {
                                            <span class="badge @(result.GPA.Value >= 3.0 ? "bg-success" : "bg-warning text-dark")">@result.Grade</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Pending</span>
                                        }
                                    </td>
                                    <td class="text-center fw-bold">
                                        @(result.GPA.HasValue ? result.GPA.Value.ToString("0.00") : "-")
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
        <div class="panel-footer">
            <a asp-action="Dashboard" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Back to Dashboard
            </a>
        </div>
    </div>
</div>
