@{
    ViewData["Title"] = "Student Dashboard";
}

<div class="container page-container">
    <div class="row">
        <div class="centered-wrapper">
            <div class="panel">
                <div class="panel-header-success">
                    <h3 class="mb-0">Student Dashboard</h3>
                </div>
                <div class="panel-body">
                    <h4 class="card-title">Welcome, @User.Identity.Name!</h4>
                    <p class="card-text text-muted">You are successfully logged in to the student portal.</p>
                    
                    <hr />
                    
                    <div class="dashboard-grid">
                        <div class="dashboard-card-wrapper" style="max-width: 33.33%; flex: 0 0 33.33%;">
                            <div class="dashboard-card">
                                <i class="bi bi-book dashboard-icon icon-primary"></i>
                                <h5 class="dashboard-card-title">My Courses</h5>
                                <p class="dashboard-card-subtitle">View your enrolled courses</p>
                            </div>
                        </div>
                        <div class="dashboard-card-wrapper" style="max-width: 33.33%; flex: 0 0 33.33%;">
                            <a href="/Student/RegisterCourses" class="dashboard-card">
                                <i class="bi bi-plus-circle dashboard-icon icon-success"></i>
                                <h5 class="dashboard-card-title">Register Courses</h5>
                                <p class="dashboard-card-subtitle">Browse and enroll</p>
                            </a>
                        </div>
                        <div class="dashboard-card-wrapper" style="max-width: 33.33%; flex: 0 0 33.33%;">
                            <div class="dashboard-card">
                                <i class="bi bi-person-badge dashboard-icon icon-primary"></i>
                                <h5 class="dashboard-card-title">My Profile</h5>
                                <p class="dashboard-card-subtitle">Update your details</p>
                            </div>
                        </div>
                    </div>
                    <div class="dashboard-grid">
                        <div class="dashboard-card-wrapper" style="max-width: 33.33%; flex: 0 0 33.33%;">
                            <a asp-action="ViewAssignments" class="dashboard-card">
                                <i class="bi bi-file-earmark-text dashboard-icon icon-warning"></i>
                                <h5 class="dashboard-card-title">My Assignments</h5>
                                <p class="dashboard-card-subtitle">View assignments for your courses</p>
                            </a>
                        </div>
                    </div>
                </div>
                <div class="panel-footer">
                    <a href="/Account/Logout" class="btn btn-outline-danger">
                        <i class="bi bi-box-arrow-right"></i> Logout
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
