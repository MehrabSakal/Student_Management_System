@model IEnumerable<StudentManagementSystem.Models.StudentAttendanceSummary>
@{
    ViewData["Title"] = "My Attendance";
}

<div class="container page-container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="panel">
                <div class="panel-header-info d-flex justify-content-between align-items-center">
                    <h3 class="mb-0"><i class="bi bi-calendar-check me-2"></i>Attendance Summary</h3>
                </div>
                <div class="panel-body">
                    @if (!Model.Any())
                    {
                        <div class="alert alert-info">
                            No attendance records found. Your teachers have not taken attendance yet.
                        </div>
                    }
                    else
                    {
                        <div class="row g-4">
                            @foreach (var summary in Model)
                            {
                                <div class="col-md-6">
                                    <div class="card bg-dark border-secondary h-100">
                                        <div class="card-body">
                                            <h5 class="card-title text-light mb-1">@summary.CourseName</h5>
                                            <p class="text-muted small mb-3">Course No: @summary.CourseNo</p>
                                            
                                            <div class="d-flex justify-content-between align-items-end mb-2">
                                                <span class="text-light">Attendance</span>
                                                <span class="fs-4 fw-bold @(summary.AttendancePercentage >= 75 ? "text-success" : (summary.AttendancePercentage >= 60 ? "text-warning" : "text-danger"))">
                                                    @summary.AttendancePercentage.ToString("0.0")%
                                                </span>
                                            </div>
                                            
                                            <div class="progress bg-secondary" style="height: 10px;">
                                                <div class="progress-bar @(summary.AttendancePercentage >= 75 ? "bg-success" : (summary.AttendancePercentage >= 60 ? "bg-warning" : "bg-danger"))" 
                                                     role="progressbar" 
                                                     style="width: @summary.AttendancePercentage%;" 
                                                     aria-valuenow="@summary.AttendancePercentage" 
                                                     aria-valuemin="0" 
                                                     aria-valuemax="100">
                                                </div>
                                            </div>
                                            
                                            @if (summary.AttendancePercentage < 75)
                                            {
                                                <div class="mt-2 text-danger small">
                                                    <i class="bi bi-exclamation-triangle me-1"></i> Below 75% requirement
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
                <div class="panel-footer text-center">
                    <a asp-action="Dashboard" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Back to Dashboard
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
