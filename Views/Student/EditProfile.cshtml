@model StudentManagementSystem.Models.Student
@{
    ViewData["Title"] = "Edit Profile";
}

<div class="container page-container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="panel">
                <div class="panel-header-info">
                    <h3 class="mb-0"><i class="bi bi-pencil-square me-2"></i>Edit Profile</h3>
                </div>
                <div class="panel-body">
                    <form asp-action="EditProfile" method="post">
                        @if (TempData["ErrorMessage"] != null)
                        {
                            <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
                        }

                        <div class="form-group mb-3">
                            <label class="form-label text-muted">Student ID (Unchangeable)</label>
                            <input type="text" class="form-control" value="@Model.StudentId" disabled />
                        </div>
                        <div class="form-group mb-3">
                            <label class="form-label text-muted">Full Name (Unchangeable)</label>
                            <input type="text" class="form-control" value="@Model.FullName" disabled />
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Email" class="form-label">Email Address</label>
                            <input asp-for="Email" type="email" class="form-control" required />
                        </div>
                        <div class="form-group mb-3">
                            <label asp-for="Phone" class="form-label">Phone Number</label>
                            <input asp-for="Phone" type="text" class="form-control" required />
                        </div>
                        <div class="form-group mb-3">
                            <label asp-for="Address" class="form-label">Address</label>
                            <textarea asp-for="Address" class="form-control" rows="2" required></textarea>
                        </div>
                        
                        <hr class="my-4 border-secondary" />
                        
                        <div class="form-group mb-4">
                            <label asp-for="Password" class="form-label">New Password</label>
                            <input asp-for="Password" type="password" class="form-control" placeholder="Leave blank to keep current password" value="" />
                            <small class="text-muted">Only fill this if you want to change your password.</small>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">Save Changes</button>
                        </div>
                    </form>
                </div>
                <div class="panel-footer text-center">
                    <a asp-action="MyProfile" class="btn btn-outline-secondary w-100">
                        Cancel
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
