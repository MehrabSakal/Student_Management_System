@{
    ViewData["Title"] = "Teacher Dashboard";
}

<div class="container page-container">
    <div class="row">
        <div class="centered-wrapper">
            <div class="panel">
                <div class="panel-header-info">
                    <h3 class="mb-0">Teacher Dashboard</h3>
                </div>
                <div class="panel-body">
                    <h4 class="card-title">Welcome, @User.Identity.Name!</h4>
                    <p class="card-text text-muted">You are successfully logged in to the teacher portal.</p>
                    
                    <hr />
                    
                    <div class="dashboard-grid">
                        <div class="dashboard-card-wrapper">
                            <a asp-action="MyAdvisees" class="dashboard-card">
                                <i class="bi bi-people dashboard-icon icon-info"></i>
                                <h5 class="dashboard-card-title">My Advisees</h5>
                                <p class="dashboard-card-subtitle">Manage your advising students</p>
                            </a>
                        </div>
                        <div class="dashboard-card-wrapper">
                            <div class="dashboard-card">
                                <i class="bi bi-calendar-check dashboard-icon icon-info"></i>
                                <h5 class="dashboard-card-title">Class Schedule</h5>
                                <p class="dashboard-card-subtitle">View your upcoming classes</p>
                            </div>
                        </div>
                    </div>
                    <div class="dashboard-grid">
                        <div class="dashboard-card-wrapper">
                            <a asp-action="GiveAssignment" class="dashboard-card">
                                <i class="bi bi-file-earmark-plus dashboard-icon icon-success"></i>
                                <h5 class="dashboard-card-title">Give Assignment</h5>
                                <p class="dashboard-card-subtitle">Create assignments or projects</p>
                            </a>
                        </div>
                        <div class="dashboard-card-wrapper">
                            <a asp-action="ViewAssignments" class="dashboard-card">
                                <i class="bi bi-file-earmark-text dashboard-icon icon-primary"></i>
                                <h5 class="dashboard-card-title">My Assignments</h5>
                                <p class="dashboard-card-subtitle">View assignments you have given</p>
                            </a>
                        </div>
                    </div>
                </div>
                <div class="panel-footer">
                    <a href="/Account/Logout" class="btn btn-outline-danger">
                        <i class="bi bi-box-arrow-right"></i> Logout
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
