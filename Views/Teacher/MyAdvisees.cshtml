@model IEnumerable<StudentManagementSystem.Models.Student>
@{
    ViewData["Title"] = "My Advisees";
}

<div class="container page-container">
    <div class="row">
        <div class="col-md-12">
            <div class="panel">
                <div class="panel-header-info d-flex justify-content-between align-items-center">
                    <h3 class="mb-0">My Advisees</h3>
                    <a asp-action="Dashboard" class="btn btn-outline-light btn-sm">
                        <i class="bi bi-arrow-left"></i> Back to Dashboard
                    </a>
                </div>
                <div class="panel-body p-0">
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger m-3">
                            @TempData["ErrorMessage"]
                        </div>
                    }

                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>Student ID</th>
                                    <th>Full Name</th>
                                    <th>Email</th>
                                    <th>Phone</th>
                                    <th>Department</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Any())
                                {
                                    foreach (var student in Model)
                                    {
                                        <tr>
                                            <td>@student.StudentId</td>
                                            <td>@student.FullName</td>
                                            <td>@student.Email</td>
                                            <td>@student.Phone</td>
                                            <td>@student.DeptId</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-center py-4">
                                            <div class="text-muted">
                                                <i class="bi bi-info-circle" style="font-size: 2rem;"></i>
                                                <p class="mt-2">No advisees assigned yet.</p>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
