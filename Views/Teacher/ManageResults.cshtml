@model IEnumerable<StudentManagementSystem.Models.Course>
@{
    ViewData["Title"] = "Manage Results";
}

<div class="container page-container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="panel">
                <div class="panel-header-info">
                    <h3 class="mb-0"><i class="bi bi-journal-check me-2"></i>Manage Course Results</h3>
                </div>
                <div class="panel-body">
                    <p class="text-muted">Select a course to manage marks and assign grades to enrolled students.</p>
                    
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
                    }

                    <div class="list-group mt-4">
                        @foreach (var course in Model)
                        {
                            <a asp-action="CourseResults" asp-route-courseNo="@course.CourseNo" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center" style="background-color: transparent; border-color: #334155;">
                                <div>
                                    <h5 class="mb-1 fw-bold" style="color: #f1f5f9;">@course.CourseName</h5>
                                    <small style="color: #94a3b8;">@course.CourseNo | @course.CourseType | Dept: @course.DeptId</small>
                                </div>
                                <i class="bi bi-chevron-right text-primary"></i>
                            </a>
                        }
                    </div>
                </div>
                <div class="panel-footer">
                    <a asp-action="Dashboard" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Back to Dashboard
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
